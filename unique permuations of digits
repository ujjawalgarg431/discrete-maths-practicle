#include <iostream>
#include <algorithm>
using namespace std;

// simple factorial function
int factorial(int n) {
    int f = 1;
    for(int i = 1; i <= n; i++) {
        f = f * i;
    }
    return f;
}

int main() {
    string s;
    cout << "Enter digits: ";
    cin >> s;

    // sort the string first
    sort(s.begin(), s.end());

    int count = 0;

    cout << "\nPermutations are:\n";

    // print all unique permutations
    do {
        cout << s << endl;
        count++;
    } while(next_permutation(s.begin(), s.end()));

    cout << "\nTotal permutations = " << count << endl;

    // -------- formula part --------

    int n = s.length();
    int freq[10] = {0};  // for digits 0-9

    // count frequency of each digit
    for(int i = 0; i < n; i++) {
        freq[s[i] - '0']++;
    }

    int result = factorial(n);

    // divide by factorial of frequencies
    for(int i = 0; i < 10; i++) {
        if(freq[i] > 1) {
            result = result / factorial(freq[i]);
        }
    }

    cout << "Using formula = " << result << endl;

    // check
    if(count == result) {
        cout << "Correct! Both match 👍" << endl;
    } else {
        cout << "Something is wrong ❌" << endl;
    }

    return 0;
}
